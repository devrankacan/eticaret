# ============================================
# Hostinger Node.js için Environment Variables
# Bu değerleri Hostinger panelinden ayarlayın
# ============================================

# Next.js Auth (ZORUNLU)
NEXTAUTH_URL=https://siteniz.com
NEXTAUTH_SECRET=BURAYA_EN_AZ_32_KARAKTERLIK_RASTGELE_STRING

# PostgreSQL - Neon.tech bağlantısı (ZORUNLU)
DATABASE_URL="postgresql://USER:PASS@ep-dark-smoke-a4ctxrlx.us-east-1.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@ep-dark-smoke-a4ctxrlx.us-east-1.aws.neon.tech/dbname?sslmode=require"

# Uygulama
NODE_ENV=production

# E-posta - Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@atesoglusut.com
SMTP_PASS=sifreniz

# İyzico Ödeme (opsiyonel)
# IYZIPAY_API_KEY=
# IYZIPAY_SECRET_KEY=
